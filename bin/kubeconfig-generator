#!/usr/bin/env python3

# Mints a fresh *temporary* token for the ai-agent ServiceAccount and writes a
# pinned kubeconfig that kubectl-readonly consumes. Everything is hardcoded:
#
#   ServiceAccount : ai-agent
#   namespace      : default
#   token          : temporary (TokenRequest API), expires after 1h
#   output         : ~/.kube/ai-agent.kubeconfig
#
# It takes no arguments. Run with admin credentials (the read-only SA cannot
# mint its own token); the current context supplies the cluster, server, and CA.
#
# Before minting anything we fail fast unless the ai-agent SA's RBAC is
# genuinely read-only: we impersonate the SA and probe the write verbs, and
# refuse to issue a token the moment any of them is permitted. This guarantees
# the kubeconfig we hand to kubectl-readonly can only ever read.

import os
import subprocess
import sys
from typing import NoReturn

SA, NS = "ai-agent", "default"
DURATION = "1h"
KUBECONFIG = os.path.join(os.path.expanduser("~"), ".kube", "ai-agent.kubeconfig")

# Verbs that mutate the cluster. A read-only RBAC role grants only get/list/watch;
# if the SA can do any of these, it is not read-only and we refuse to mint a token.
WRITE_VERBS = ("create", "update", "patch", "delete", "deletecollection")


def die(msg) -> NoReturn:
    sys.exit(f"kubeconfig-generator: {msg}")


def kubectl(*args) -> str:
    """Run kubectl against the current (admin) context and return stdout.
    Fails closed: a non-zero exit aborts with kubectl's own stderr, which is
    clear enough on its own (an expired-AWS-credential failure shows up as
    `...getting credentials: exec: ...`)."""
    proc = subprocess.run(
        ["kubectl", *args], capture_output=True, text=True
    )
    if proc.returncode != 0:
        die(f"`kubectl {' '.join(args)}` failed: {proc.stderr.strip()}")
    return proc.stdout


def get_cluster_details() -> tuple[str, str, str]:
    """Read cluster name, server URL, and inlined CA data from the current
    context, so the generated kubeconfig points at the same cluster the admin
    is currently using."""
    view = ["config", "view", "--minify", "--flatten", "-o"]
    cluster_name = kubectl(*view, "jsonpath={.clusters[0].name}").strip()
    server = kubectl(*view, "jsonpath={.clusters[0].cluster.server}").strip()
    ca = kubectl(
        *view, "jsonpath={.clusters[0].cluster.certificate-authority-data}"
    ).strip()
    if not (cluster_name and server and ca):
        die("could not extract cluster name, server, or CA data from the "
            "current context.")
    return cluster_name, server, ca


def verify_service_account_exists() -> None:
    """Abort early if the ai-agent SA is missing, rather than letting
    `kubectl create token` fail later with a noisier error. Goes through
    kubectl() so a connection failure (e.g. expired AWS token) surfaces
    kubectl's own error instead of wrongly blaming a missing SA."""
    kubectl("get", "serviceaccount", SA, "-n", NS)


def assert_readonly_rbac() -> None:
    """Fail fast unless the ai-agent SA is genuinely read-only. Impersonating the
    SA (which admin credentials may do), probe each write verb against every
    resource in the SA's namespace; a single 'yes' means the SA can mutate the
    cluster, so we refuse to mint a token for it. A cluster-wide write grant
    (ClusterRoleBinding) also surfaces here, since it applies in this namespace."""
    user = f"system:serviceaccount:{NS}:{SA}"
    for verb in WRITE_VERBS:
        proc = subprocess.run(
            ["kubectl", "auth", "can-i", verb, "*", "-n", NS, f"--as={user}"],
            capture_output=True, text=True,
        )
        answer = proc.stdout.strip()
        if answer == "yes":
            die(f"refusing to issue a token: {SA} can '{verb}' resources in "
                f"namespace '{NS}' — its RBAC is not read-only.")
        if answer != "no":
            # Neither a clean allow nor deny: impersonation may be forbidden or
            # the cluster is unreachable. Fail closed rather than mint blindly.
            detail = proc.stderr.strip() or repr(answer)
            die(f"could not confirm {SA}'s RBAC is read-only "
                f"(`auth can-i {verb} '*'` said: {detail}).")


def issue_temporary_token() -> str:
    """Issue a bound, expiring token via the TokenRequest API."""
    print(f"Requesting temporary token for {SA} (duration: {DURATION})...")
    token = kubectl(
        "create", "token", SA, "-n", NS, f"--duration={DURATION}"
    ).strip()
    if not token:
        die("failed to issue temporary token.")
    return token


def render_kubeconfig(cluster_name, server, ca, token) -> None:
    """Write the kubeconfig with 0600 permissions (it carries a bearer token).
    Refuse to follow a symlink, so the token can't be redirected to another
    file's target."""
    print(f"Rendering kubeconfig to '{KUBECONFIG}'...")
    if os.path.islink(KUBECONFIG):
        die(f"'{KUBECONFIG}' is a symlink; refusing to write bearer token to "
            "symlink target.")
    contents = f"""\
apiVersion: v1
kind: Config
clusters:
  - name: {cluster_name}
    cluster:
      certificate-authority-data: {ca}
      server: {server}
contexts:
  - name: {SA}@{cluster_name}
    context:
      cluster: {cluster_name}
      namespace: {NS}
      user: {SA}
users:
  - name: {SA}
    user:
      token: {token}
current-context: {SA}@{cluster_name}
"""
    os.makedirs(os.path.dirname(KUBECONFIG), exist_ok=True)
    try:
        os.remove(KUBECONFIG)
    except FileNotFoundError:
        pass
    fd = os.open(KUBECONFIG, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
    with os.fdopen(fd, "w") as f:
        f.write(contents)
    print(f"Done. Kubeconfig written to: {KUBECONFIG}")


def main() -> None:
    if len(sys.argv) > 1:
        die("takes no arguments; SA, namespace, duration, and output path are "
            "fixed (ai-agent / default / 1h / ~/.kube/ai-agent.kubeconfig).")
    cluster_name, server, ca = get_cluster_details()
    verify_service_account_exists()
    assert_readonly_rbac()
    token = issue_temporary_token()
    render_kubeconfig(cluster_name, server, ca, token)


if __name__ == "__main__":
    main()
